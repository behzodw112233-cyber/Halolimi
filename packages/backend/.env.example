# Stripe secret values belong only in Convex environment variables.
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me

# Stripe does not support UZS as a presentment currency. Keep product and wallet
# values in UZS, then override the USD fallback with your locked checkout rate.
STRIPE_CURRENCY=usd
STRIPE_UZS_PER_CURRENCY_UNIT=13000

# Return URLs used by Stripe Checkout after a payment attempt.
STRIPE_SUCCESS_URL=halolmia://jamgarma?payment=success
STRIPE_CANCEL_URL=halolmia://jamgarma?payment=cancelled
