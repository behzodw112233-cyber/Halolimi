PAYME_ID=your_payme_id
PAYME_KEY=your_payme_key

CLICK_SERVICE_ID=your_service_id
CLICK_MERCHANT_ID=your_merchant_id
CLICK_MERCHANT_USER_ID=your_merchant_user_id
CLICK_SECRET_KEY=your_secret_key

ATMOS_CONSUMER_KEY=your_atmos_consumer_key
ATMOS_CONSUMER_SECRET=your_atmos_consumer_secret
ATMOS_STORE_ID=your_atmos_store_id
ATMOS_TERMINAL_ID=your_atmos_terminal_id
ATMOS_API_KEY=your_atmos_api_key

IS_TEST_MODE=True
PAYTECH_LICENSE_API_KEY=your_license_key

# Convex callback target. Must match Convex env PAYTECH_CALLBACK_SECRET.
CONVEX_PAYTECH_CALLBACK_URL=https://your-convex-site.convex.site/paytech/callback
PAYTECH_CALLBACK_SECRET=change_me

# Optional shared token required from Convex when creating orders.
PAYTECH_SERVICE_TOKEN=change_me

# Optional: point to a deployed PayTechUz example service and use it for order creation.
PAYTECH_UPSTREAM_URL=

# Dev only. Overrides checkout links returned to the app. Use localhost for Expo Web.
PAYTECH_PUBLIC_BASE_URL=http://127.0.0.1:8000

# Dev only. When True, returns a fake checkout URL if no upstream adapter is configured.
PAYTECH_ALLOW_FAKE_LINKS=False
