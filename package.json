{
  "name": "halolmia",
  "private": true,
  "version": "0.0.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "packageManager": "npm@11.16.0",
  "dependencies": {
    "convex": "^1.42.1"
  },
  "overrides": {
    "react-native-reanimated": "4.5.0",
    "react-native-safe-area-context": "5.7.0",
    "react-native-svg": "15.15.4"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "dev:services": "concurrently -k -n convex,admin,bot -c blue,magenta,green \"convex dev\" \"npm run dev -w @halolmia/admin\" \"npm run dev:poll -w @halolmia/bot\"",
    "dev:mobile": "npm run dev -w @halolmia/mobile",
    "dev:paytech": "npm run dev -w @halolmia/paytech",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "clean": "turbo run clean",
    "deploy:admin": "scripts\\deploy-admin.cmd vercel",
    "build:admin": "npm run build -w @halolmia/admin"
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "turbo": "^2.5.8"
  },
  "engines": {
    "node": ">=18"
  },
  "allowScripts": {
    "esbuild@0.28.1": true
  }
}
