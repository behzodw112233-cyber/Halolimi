# Get a token from @BotFather on Telegram
BOT_TOKEN=123456:ABC-your-telegram-bot-token

# Webhook mode
PORT=8080
# Public HTTPS base URL that forwards to this server (e.g. an ngrok URL).
# Telegram will POST updates to  <WEBHOOK_URL>/webhook
WEBHOOK_URL=https://your-public-url.ngrok-free.app
# Shared secret validated on every incoming Telegram request
WEBHOOK_SECRET=halolmi_secret
