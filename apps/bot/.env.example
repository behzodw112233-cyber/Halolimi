# Get a token from @BotFather on Telegram
BOT_TOKEN=123456:ABC-your-telegram-bot-token

# Convex deployment URL (required)
CONVEX_URL=https://your-deployment.convex.cloud

# --- Pella / free bot hosts ---
# Leave WEBHOOK_URL empty → long-polling (recommended on Pella).

# --- Webhook mode (optional, public HTTPS host) ---
# PORT=8080
# WEBHOOK_URL=https://your-public-url.example
# WEBHOOK_SECRET=halolmi_secret
